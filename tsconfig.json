{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"]
  },
  "include": [
    "src/**/*",
    "*.ts",
    "**/*.ts",
    "**/*.js",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "dist", "build"]
}